[Unit]
Description=SafeRouter proxy
After=network.target

[Service]
User=__SERVICE_USER__
WorkingDirectory=/opt/saferouter
EnvironmentFile=-/etc/saferouter/saferouter.env
ExecStart=/bin/sh -lc '/opt/saferouter/sr proxy --upstream "$UPSTREAM" --listen "$LISTEN" --mode "$MODE" --log "$LOG"'
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/var/log/saferouter /var/lib/saferouter

[Install]
WantedBy=multi-user.target
