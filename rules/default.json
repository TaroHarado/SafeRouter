{
  "rules": [
    {
      "id": "dl-curl-pipe-sh",
      "category": "download-exec",
      "pattern": "(?i)curl(?:\\s+https?://[^|\\s]+)?\\s*\\|\\s*(?:sh|bash|zsh|pwsh|ash|dash)",
      "severity": 95
    },
    {
      "id": "dl-wget-pipe-sh",
      "category": "download-exec",
      "pattern": "(?i)wget(?:\\s+https?://[^|\\s]+)?\\s*-O\\s*[^|\\s]+\\s*\\|\\s*(?:sh|bash|zsh|ash|dash)",
      "severity": 95
    },
    {
      "id": "dl-irm-iex",
      "category": "download-exec",
      "pattern": "(?i)irm\\s+https?://[^|\\s]+\\s*\\|\\s*iex",
      "severity": 95
    },
    {
      "id": "dl-iwr-iex",
      "category": "download-exec",
      "pattern": "(?i)iwr\\s+https?://[^|\\s]+\\s*\\|\\s*iex",
      "severity": 95
    },
    {
      "id": "dl-invoke-webrequest",
      "category": "download-exec",
      "pattern": "(?i)Invoke-WebRequest[^|]*\\|\\s*Invoke-Expression",
      "severity": 95
    },
    {
      "id": "obfusc-base64-pipe",
      "category": "obfuscation",
      "pattern": "(?i)(?:base64|b64|openssl)\\s+(?:-d|--decode)\\s*(?:[^|]*\\s*)?\\|\\s*(?:sh|bash|zsh|pwsh)",
      "severity": 90
    },
    {
      "id": "persist-schtasks",
      "category": "persistence",
      "pattern": "(?i)schtasks\\s+/(?:create|register)",
      "severity": 85
    },
    {
      "id": "persist-launchctl",
      "category": "persistence",
      "pattern": "(?i)launchctl\\s+(?:load|bootstrap)",
      "severity": 85
    },
    {
      "id": "persist-cron-edit",
      "category": "persistence",
      "pattern": "(?i)\\(crontab\\s+-l(?:;\\s*echo\\s+[^)]+)?;\\s*crontab\\s*-\\)",
      "severity": 85
    },
    {
      "id": "persist-systemd-unit-write",
      "category": "persistence",
      "pattern": "(?i)\\[Unit\\][^\\[]*\\[Service\\][^\\[]*\\[Install\\]",
      "severity": 80
    },
    {
      "id": "net-socks5-proxy-env",
      "category": "network",
      "pattern": "(?i)(?:ALL_PROXY|HTTP_PROXY|HTTPS_PROXY)\\s*=\\s*socks5://",
      "severity": 80
    },
    {
      "id": "net-iex-env-change",
      "category": "network",
      "pattern": "(?i)setx\\s+(?:ALL_PROXY|HTTP_PROXY|HTTPS_PROXY)",
      "severity": 80
    },
    {
      "id": "net-dns-change",
      "category": "network",
      "pattern": "(?i)(?:resolv\\.conf|/etc/resolv\\.conf|nameserver\\s+\\d+\\.\\d+\\.\\d+\\.\\d+)",
      "severity": 70
    },
    {
      "id": "anti-forensics-journal",
      "category": "anti-forensics",
      "pattern": "(?i)(?:journalctl\\s+--vacuum|rm\\s+-rf?\\s+/var/log|rm\\s+-rf?\\s+\\$HOME/\\.bash_history|rm\\s+-rf?\\s+\\$HOME/\\.zsh_history)",
      "severity": 90
    },
    {
      "id": "anti-forensics-history-unset",
      "category": "anti-forensics",
      "pattern": "(?i)unset\\s+HISTFILE",
      "severity": 60
    },
    {
      "id": "locale-change-unexpected",
      "category": "locale",
      "pattern": "(?i)(?:export\\s+)?LANG\\s*=\\s*(?:C|en_US\\.UTF-8)(?:\\sLinux)?\\s*(?:\\n|;|$)",
      "severity": 30
    },
    {
      "id": "rce-rm-rf-root",
      "category": "anti-forensics",
      "pattern": "(?i)rm\\s+-rf?\\s+(?:/|/\\*|\\*/|\\$HOME/?\\s*$)",
      "severity": 95
    },
    {
      "id": "rce-pyexec-unencoded",
      "category": "obfuscation",
      "pattern": "(?i)python3?\\s+-c\\s+['\"]import(?:\\s+os|\\s+urllib|\\s+subprocess)",
      "severity": 70
    },
    {
      "id": "unobfuscated-c2-fetch",
      "category": "download-exec",
      "pattern": "(?i)(?:curl|wget|irm|iwr)\\s+https?://[a-z0-9.-]+\\.(?:ru|cn|tk|xyz|top|info)/[a-z0-9_-]+\\.(?:ps1|sh|exe|dll|bin)",
      "severity": 85
    }
  ]
}